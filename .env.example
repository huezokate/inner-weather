# Inner Weather — environment variables.
# Local dev: copy to `.env.local` and fill in (gitignored via *.local).
# Production (Vercel): set these in Project → Settings → Environment Variables.

# ── Server-side only (Vercel) — NEVER prefixed with VITE_ (keeps them out of the bundle).
#    The /api/* serverless functions read these. Locally, dev uses the VITE_ copies below.
YOU_API_KEY=          # You.com Search API key  → used by api/youcom.ts
OURA_TOKEN=           # Oura Personal Access Token → used by api/oura.ts

# ── Client-side (bundled). Safe to expose: the InsForge anon key is public by design and
#    protected by row-level security. Set the same VITE_ names in Vercel too.
VITE_INSFORGE_BASE_URL=
VITE_INSFORGE_ANON_KEY=

# ── Local dev ONLY. In dev the client talks to the Vite proxy and sends these itself.
#    Do NOT set these in Vercel (prod uses the server-side YOU_API_KEY / OURA_TOKEN above).
VITE_YOU_API_KEY=
VITE_OURA_TOKEN=
